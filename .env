# Токен Discord-бота
DISCORD_TOKEN=твой_токен

# Ссылка на Google Таблицу
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/xxxxx/edit

# ID канала для ежедневного отчета
REPORT_CHANNEL_ID=123456789012345678

# Лист со списком игроков
PLAYERS_SHEET_NAME=Игроки

# Лист-шаблон, который бот копирует
TEMPLATE_SHEET_NAME=Шаблон

# Часовой пояс, МСК = 3
TIMEZONE_OFFSET=3

# Скрывать ответы команд от других игроков
COMMANDS_EPHEMERAL=true

# Включить ежедневный отчет о неотметившихся
ENABLE_MISSING_REPORT=true

# Время отправки отчета
REPORT_TIME=23:00

# Дни учета: 3=четверг, 4=пятница, 5=суббота
WAR_DAYS=3,4,5

# Как часто бот отправляет очередь записей в таблицу
FLUSH_INTERVAL_SECONDS=25

# Подсветка поздней отметки отсутствия
ENABLE_LATE_MARK_COLOR=true

# После какого времени подсвечивать отсутствие
LATE_MARK_AFTER=19:00

# С какой строки начинается первый блок игрока в шаблоне
START_ROW=2

# Сколько строк занимает один игрок
BLOCK_HEIGHT=4

# До какой колонки копировать блок игрока, A:K
BLOCK_END_COLUMN_INDEX=11